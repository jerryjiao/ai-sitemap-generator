---
interface Props {
  size?: number;
  class?: string;
}

const { size = 28, class: className = '' } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 28 28"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
>
  <defs>
    <linearGradient id="logo-grad" x1="0" y1="0" x2="28" y2="28" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#6366f1" />
      <stop offset="100%" stop-color="#8b5cf6" />
    </linearGradient>
  </defs>
  <!-- Central node -->
  <circle cx="14" cy="5" r="2.5" fill="url(#logo-grad)" />
  <!-- Level 1 nodes -->
  <circle cx="6" cy="15" r="2" fill="url(#logo-grad)" opacity="0.8" />
  <circle cx="14" cy="15" r="2" fill="url(#logo-grad)" opacity="0.8" />
  <circle cx="22" cy="15" r="2" fill="url(#logo-grad)" opacity="0.8" />
  <!-- Level 2 nodes -->
  <circle cx="3" cy="24" r="1.5" fill="url(#logo-grad)" opacity="0.6" />
  <circle cx="9" cy="24" r="1.5" fill="url(#logo-grad)" opacity="0.6" />
  <circle cx="19" cy="24" r="1.5" fill="url(#logo-grad)" opacity="0.6" />
  <circle cx="25" cy="24" r="1.5" fill="url(#logo-grad)" opacity="0.6" />
  <!-- Connecting lines -->
  <line x1="14" y1="7.5" x2="6" y2="13" stroke="url(#logo-grad)" stroke-width="1.2" opacity="0.5" />
  <line x1="14" y1="7.5" x2="14" y2="13" stroke="url(#logo-grad)" stroke-width="1.2" opacity="0.5" />
  <line x1="14" y1="7.5" x2="22" y2="13" stroke="url(#logo-grad)" stroke-width="1.2" opacity="0.5" />
  <line x1="6" y1="17" x2="3" y2="22.5" stroke="url(#logo-grad)" stroke-width="1" opacity="0.35" />
  <line x1="6" y1="17" x2="9" y2="22.5" stroke="url(#logo-grad)" stroke-width="1" opacity="0.35" />
  <line x1="22" y1="17" x2="19" y2="22.5" stroke="url(#logo-grad)" stroke-width="1" opacity="0.35" />
  <line x1="22" y1="17" x2="25" y2="22.5" stroke="url(#logo-grad)" stroke-width="1" opacity="0.35" />
</svg>
