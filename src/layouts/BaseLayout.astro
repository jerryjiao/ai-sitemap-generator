---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'AI Sitemap Generator', description = 'Generate SEO-optimized sitemaps with AI-powered insights. Crawl any website, detect SEO issues, and export sitemap.xml files.' } = Astro.props;

const siteUrl = (Astro.site ? Astro.site.href : 'https://ai-sitemap-generator.pages.dev').replace(/\/+$/, '');
const canonicalUrl = new URL(Astro.url.pathname, Astro.site || 'https://ai-sitemap-generator.pages.dev');
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="AI Sitemap Generator" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl.href} />
    <style is:global>
      @import "../styles/global.css";
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
