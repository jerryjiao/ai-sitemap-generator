---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Terms of Service — AI Sitemap Generator';
const description = 'Terms of Service for AI Sitemap Generator. Free, open-source SEO tool terms: no warranty, no liability, use at your own risk.';
---

<BaseLayout {title} {description}>
  <div class="min-h-screen bg-[var(--color-background)] text-[var(--color-foreground)]">
    <nav class="sticky top-0 z-50 backdrop-blur-xl bg-[var(--color-background)]/80 border-b border-[var(--color-border)]/60 px-4 sm:px-6 py-3.5">
      <div class="max-w-4xl mx-auto flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-[var(--color-foreground)]">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/><polyline points="10 17 15 12 10 7"/><line x1="15" y1="12" x2="3" y2="12"/></svg>
          <span class="hidden sm:inline">AI Sitemap Generator</span>
          <span class="sm:hidden">SitemapGen</span>
        </a>
        <a href="/tools/sitemap" class="text-sm font-medium bg-[var(--color-primary)] text-white px-4 py-1.5 rounded-lg hover:opacity-90 transition-opacity">
          Launch Tool
        </a>
      </div>
    </nav>

    <article class="max-w-3xl mx-auto px-6 py-16">
      <header class="mb-12">
        <div class="text-sm text-[var(--color-muted-foreground)] mb-4">
          <a href="/" class="hover:text-[var(--color-foreground)] transition-colors">Home</a>
          <span class="mx-2">/</span>
          <span>Terms of Service</span>
        </div>
        <h1 class="text-3xl sm:text-4xl font-bold leading-tight mb-4">Terms of Service</h1>
        <p class="text-lg text-[var(--color-muted-foreground)]">Last updated: May 18, 2026</p>
      </header>

      <div class="prose-container space-y-8 text-[var(--color-foreground)] leading-relaxed">
        <section>
          <p class="text-[var(--color-muted-foreground)] text-lg">
            By using AI Sitemap Generator ("the Tool"), you agree to these terms. This is a free, open-source tool — we keep things simple.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-4">1. Acceptance of Terms</h2>
          <p class="text-[var(--color-muted-foreground)]">
            By accessing or using the Tool, you acknowledge that you have read, understood, and agree to be bound by these Terms of Service. If you do not agree, please do not use the Tool.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-4">2. Description of Service</h2>
          <p class="text-[var(--color-muted-foreground)]">
            AI Sitemap Generator is a free web-based tool that:
          </p>
          <ul class="mt-3 space-y-2 list-disc list-inside text-[var(--color-muted-foreground)]">
            <li>Crawls publicly accessible websites to discover pages</li>
            <li>Generates XML sitemap files compliant with the sitemaps.org protocol</li>
            <li>Detects common SEO issues (broken links, missing titles, etc.)</li>
            <li>Provides visual site structure representation</li>
            <li>Offers optional AI-powered suggestions (BYOK — Bring Your Own API Key)</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-4">3. Use of the Tool</h2>
          <div class="space-y-4 text-[var(--color-muted-foreground)]">
            <p><strong class="text-[var(--color-foreground)]">You may:</strong></p>
            <ul class="list-disc list-inside space-y-1 ml-4">
              <li>Use the Tool for personal or commercial purposes</li>
              <li>Generate sitemaps for any website you own or have permission to crawl</li>
              <li>Download and use generated sitemap files freely</li>
              <li>View and copy the open-source code from our GitHub repository</li>
            </ul>
            <p class="mt-4"><strong class="text-[var(--color-foreground)]">You must not:</strong></p>
            <ul class="list-disc list-inside space-y-1 ml-4">
              <li>Use the Tool for any unlawful purpose or to crawl sites without authorization</li>
              <li>Attempt to overload, abuse, or disrupt the service or infrastructure</li>
              <li>Reverse-engineer, modify, or create derivative works except as permitted by the open-source license</li>
              <li>Use the automated crawling feature to violate any website's robots.txt directives or Terms of Service</li>
              <li>Misrepresent the origin of sitemaps generated by the Tool</li>
            </ul>
          </div>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-4">4. No Warranty</h2>
          <p class="text-[var(--color-muted-foreground)]">
            THE TOOL IS PROVIDED "AS IS" AND "AS AVAILABLE" WITHOUT WARRANTIES OF ANY KIND, WHETHER EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO IMPLIED WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE, AND NON-INFRINGEMENT. We do not guarantee that:
          </p>
          <ul class="mt-3 space-y-2 list-disc list-inside text-[var(--color-muted-foreground)]">
            <li>The Tool will be uninterrupted, timely, secure, or error-free</li>
            <li>The results generated are complete or fully accurate</li>
            <li>The generated sitemaps will improve your search engine rankings</li>
            <li>The AI suggestions (when enabled) are correct or suitable for your use case</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-4">5. Limitation of Liability</h2>
          <p class="text-[var(--color-muted-foreground)]">
            TO THE MAXIMUM EXTENT PERMITTED BY APPLICABLE LAW, THE OPERATORS OF AI SITEMAP GENERATOR SHALL NOT BE LIABLE FOR ANY INDIRECT, INCIDENTAL, SPECIAL, CONSEQUENTIAL, OR PUNITIVE DAMAGES ARISING FROM YOUR USE OR INABILITY TO USE THE TOOL, EVEN IF ADVISED OF THE POSSIBILITY OF SUCH DAMAGES. The Tool is provided free of charge, and we accept no liability for any loss or damage arising from its use.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-4">6. Your Responsibility</h2>
          <p class="text-[var(--color-muted-foreground)]">
            You are solely responsible for:
          </p>
          <ul class="mt-3 space-y-2 list-disc list-inside text-[var(--color-muted-foreground)]">
            <li>Ensuring you have permission to crawl any website you analyze</li>
            <li>Reviewing and validating generated sitemaps before submitting to search engines</li>
            <li>Safeguarding any API keys you choose to provide for AI features</li>
            <li>Complying with the Terms of Service of websites you crawl</li>
            <li>Complying with all applicable laws and regulations in your jurisdiction</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-4">7. AI Features (BYOK)</h2>
          <p class="text-[var(--color-muted-foreground)]">
            Optional AI features require you to provide your own API key from a third-party AI provider. By using these features, you acknowledge that:
          </p>
          <ul class="mt-3 space-y-2 list-disc list-inside text-[var(--color-muted-foreground)]">
            <li>You are responsible for all costs incurred through your API key usage</li>
            <li>We are not a party to your agreement with the AI provider</li>
            <li>AI suggestions are advisory only and should be reviewed before implementation</li>
            <li>We are not liable for the output or behavior of third-party AI models</li>
          </ul>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-4">8. Open Source License</h2>
          <p class="text-[var(--color-muted-foreground)]">
            The source code of AI Sitemap Generator is licensed under an open-source license (see the LICENSE file in the GitHub repository). Any use, modification, or distribution of the source code must comply with that license's terms.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-4">9. Changes to These Terms</h2>
          <p class="text-[var(--color-muted-foreground)]">
            We may update these Terms of Service from time to time. Changes will be posted on this page with an updated revision date. Continued use of the Tool after changes constitutes acceptance of the modified terms.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-4">10. Governing Law</h2>
          <p class="text-[var(--color-muted-foreground)]">
            These Terms shall be governed by and construed in accordance with applicable law, without regard to conflict of law principles.
          </p>
        </section>

        <section>
          <h2 class="text-2xl font-bold mb-4">Contact</h2>
          <p class="text-[var(--color-muted-foreground)]">
            For questions about these Terms, please
            <a href="https://github.com/jerryjiao/ai-sitemap-generator/issues" class="text-[var(--color-primary)] hover:underline">open an issue on GitHub</a>.
          </p>
        </section>
      </div>
    </article>

    <footer class="border-t border-[var(--color-border)]/50 px-6 py-8">
      <div class="max-w-4xl mx-auto flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-[var(--color-muted-foreground)]">
        <span>&copy; 2025–2026 AI Sitemap Generator</span>
        <span>Built with Astro + Cloudflare</span>
      </div>
    </footer>
  </div>
</BaseLayout>
